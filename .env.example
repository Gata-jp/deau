# Supabase → Project Settings → Database
# Prisma Migrate には「セッション／ダイレクト」接続が向いています（ポート 5432）。
# アプリ本番のみ Transaction pooler（ポート 6543）を使う場合は Prisma のドキュメントに従い
# `?pgbouncer=true` などを付与してください。

DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres?schema=public"
MATCH_BATCH_SECRET="replace-with-a-long-random-secret"
CRON_SECRET="replace-with-the-same-or-another-long-random-secret"
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_xxx"
